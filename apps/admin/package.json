{
  "name": "@design-hub/admin",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "bun run --hot src/main.tsx",
    "build": "bun run build:client && bun run build:server",
    "build:client": "bun build src/main.tsx --outdir dist/client",
    "build:server": "bun build src/index.ts --outdir dist/server",
    "start": "bun dist/server/index.js",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "elysia": "^1.0.0",
    "@elysiajs/cors": "^1.0.0",
    "@elysiajs/jwt": "^1.0.0",
    "@design-hub/config": "workspace:*",
    "@tanstack/react-query": "^5.0.0",
    "@tanstack/react-router": "^1.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "typescript": "^5.0.0",
    "tailwindcss": "^3.4.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0"
  }
}
